{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/inject-context.cjs SessionStart json 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Loading GoalMem context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/inject-context.cjs UserPromptSubmit json 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/inject-context.cjs PostToolUse json 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Refreshing GoalMem context"
          }
        ]
      }
    ]
  }
}
