{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node plugin/codex-inject-context.cjs UserPromptSubmit json 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node plugin/codex-inject-context.cjs PostToolUse json 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Refreshing GoalMem context"
          }
        ]
      }
    ]
  }
}
